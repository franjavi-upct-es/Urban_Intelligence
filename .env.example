# .env.example
# Urban Intelligence Framework - Environment Configuration
# Copy this file to .env and modify as needed

# ===========================================================================
# Project Paths
# ===========================================================================
URBAN_PROJECT_ROOT=.
URBAN_DATABASE_PATH=data/urban_intelligence.duckdb
URBAN_RAW_DATA_PATH=data/raw
URBAN_PROCESSED_DATA_PATH=data/processed

# ===========================================================================
# MLflow Configuration
# ===========================================================================
URBAN_MLFLOW_TRACKING_URI=mlruns
URBAN_EXPERIMENT_NAME=airbnb-price-prediction

# For remote MLflow server:
# URBAN_MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_TRACKING_USERNAME=admin
# MLFLOW_TRACKING_PASSWORD=password

# ===========================================================================
# Model Training Configuration
# ===========================================================================
URBAN_N_OPTUNA_TRIALS=50
URBAN_CV_FOLDS=5
URBAN_RANDOM_SEED=42
URBAN_TEST_SIZE=0.2

# ===========================================================================
# Data Generation (for synthetic data)
# ===========================================================================
URBAN_N_SYNTHETIC_SAMPLES=10000

# ===========================================================================
# Feature Engineering
# ===========================================================================
URBAN_PRICE_MIN=10.0
URBAN_PRICE_MAX=10000.0

# ===========================================================================
# Logging
# ===========================================================================
URBAN_LOG_LEVEL=INFO

# ===========================================================================
# Data Service Configuration
# ===========================================================================
# Staleness thresholds (days)
URBAN_AIRBNB_STALENESS_DAYS=30
URBAN_WEATHER_STALENESS_DAYS=7
URBAN_POI_STALENESS_DAYS=90

# ===========================================================================
# API Configuration (for FastAPI)
# ===========================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# ===========================================================================
# Streamlit Configuration
# ===========================================================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true

# ===========================================================================
# Docker/Deployment
# ===========================================================================
COMPOSE_PROJECT_NAME=urban-intelligence

# ===========================================================================
# External APIs (no keys required for these free APIs)
# ===========================================================================
# Open-Meteo: https://open-meteo.com/ (free, no key needed)
# OpenStreetMap/Overpass: https://overpass-api.de/ (free, no key needed)
# Inside Airbnb: http://insideairbnb.com/ (free, no key needed)

# ===========================================================================
# Optional: Sentry for Error Tracking
# ===========================================================================
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ===========================================================================
# Optional: Redis for Caching
# ===========================================================================
# REDIS_URL=redis://localhost:6379/0
