# .dvc/config
# Urban Intelligence Framework - DVC Configuration
# Data Version Control settings

[core]
    autostage = true
    analytics = false

# Remote storage configuration (examples)
# Uncomment and configure as needed

# Local remote (for testing)
# [remote "local"]
#     url = /path/to/dvc-storage

# AWS S3
# [remote "s3"]
#     url = s3://your-bucket/dvc-storage
#     region = us-east-1

# Google Cloud Storage
# [remote "gcs"]
#     url = gs://your-bucket/dvc-storage

# Azure Blob Storage
# [remote "azure"]
#     url = azure://your-container/dvc-storage

# SSH/SFTP
# [remote "ssh"]
#     url = ssh://user@host/path/to/dvc-storage
