# backend/.env.example
# Urban Intelligence Framework v2.0.0
# Environment variable template — copy to .env and fill in values

# ── Application ──────────────────────────────────────────────
URBAN_LOG_LEVEL=INFO
URBAN_RANDOM_SEED=42

# ── Database ─────────────────────────────────────────────────
URBAN_DATABASE_PATH=data/urban_intelligence.db
URBAN_RAW_DATA_PATH=data/raw
URBAN_PROCESSED_DATA_PATH=data/processed

# ── MLflow ───────────────────────────────────────────────────
URBAN_MLFLOW_TRACKING_URI=http://localhost:5001
URBAN_EXPERIMENT_NAME=airbnb-price-prediction

# ── Redis ────────────────────────────────────────────────────
URBAN_REDIS_URL=redis://localhost:6379

# ── Model training ───────────────────────────────────────────
URBAN_N_OPTUNA_TRIALS=50
URBAN_CV_FOLDS=5
URBAN_TEST_SIZE=0.2

# ── Transfer learning ────────────────────────────────────────
URBAN_TRANSFER_LEARNING_ENABLED=true
URBAN_SOURCE_CITIES=london,paris,barcelona

# ── NLP ──────────────────────────────────────────────────────
URBAN_NLP_MODEL=distilbert-base-uncased
URBAN_NLP_MAX_LENGTH=128

# ── Computer vision ──────────────────────────────────────────
URBAN_CV_MODEL=efficientnet_b0
URBAN_CV_BATCH_SIZE=32

# ── API ──────────────────────────────────────────────────────
URBAN_API_RATE_LIMIT=100
URBAN_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
